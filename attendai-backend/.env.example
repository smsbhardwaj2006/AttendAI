# Django
SECRET_KEY=change-this-to-a-long-random-string
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1

# PostgreSQL
DB_NAME=attendai
DB_USER=attendai_user
DB_PASSWORD=change-this-password
DB_HOST=localhost
DB_PORT=5432

# CORS — the deployed frontend origin(s), comma-separated
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# JWT lifetimes (minutes / days)
ACCESS_TOKEN_LIFETIME_MINUTES=30
REFRESH_TOKEN_LIFETIME_DAYS=7

# AI recognition engine
# DEMO_MODE=True runs the AI pipeline with lightweight mock logic so the API
# is fully testable without downloading InsightFace model weights or owning
# a GPU. Set to False once real models are available (see apps/ai_engine/README.md).
AI_DEMO_MODE=True
AI_CONFIDENCE_THRESHOLD=94
AI_MAX_HEAD_ROTATION_DEGREES=20
AI_ANTI_SPOOFING_ENABLED=True
AI_QUALITY_CHECK_ENABLED=True
